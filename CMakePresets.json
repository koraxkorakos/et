{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "/usr/bin/gcc",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "gcc15-debug",
      "displayName": "GCC 15.2 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Gcc15Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "/usr/bin/gcc-15",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++-15",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "/usr/bin/gcc",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "gcc15-release",
      "displayName": "GCC 15.2 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Gcc15Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "/usr/bin/gcc-15",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++-15",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "clang-debug",
      "displayName": "Clang Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ClangDebug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "/usr/bin/clang",
        "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-gcc-debug",
      "configurePreset": "gcc-debug"
    },
    {
      "name": "build-gcc15-debug",
      "configurePreset": "gcc15-debug"
    },
    {
      "name": "build-gcc-release",
      "configurePreset": "gcc-release"
    },
    {
      "name": "build-gcc15-release",
      "configurePreset": "gcc15-release"
    },
    {
      "name": "build-clang-debug",
      "configurePreset": "clang-debug"
    }
  ],
  "testPresets": [
    {
      "name": "test-gcc-debug",
      "configurePreset": "gcc-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-gcc15-debug",
      "configurePreset": "gcc15-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-clang-debug",
      "configurePreset": "clang-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}