{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure gcc-debug",
      "type": "shell",
      "command": "cmake --preset gcc-debug",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake build gcc-debug",
      "type": "shell",
      "command": "cmake --build --preset build-gcc-debug -j",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "cmake configure gcc-debug",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "ctest gcc-debug",
      "type": "shell",
      "command": "ctest --preset test-gcc-debug",
      "group": "test",
      "dependsOn": "cmake build gcc-debug",
      "problemMatcher": []
    },
    {
      "label": "cmake configure clang-debug",
      "type": "shell",
      "command": "cmake --preset clang-debug",
      "problemMatcher": []
    },
    {
      "label": "cmake build clang-debug",
      "type": "shell",
      "command": "cmake --build --preset build-clang-debug -j",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "ctest clang-debug",
      "type": "shell",
      "command": "ctest --preset test-clang-debug",
      "dependsOn": "cmake build clang-debug",
      "problemMatcher": []
    }
  ]
}